<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_surface"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_sheet_handle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="600dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- Risk Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/ivRiskIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_shield_check" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvRiskLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SAFE"
                        android:textSize="24sp"
                        android:fontFamily="@font/inter_bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Risk Level"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tvFinalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textSize="28sp"
                        android:fontFamily="@font/inter_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Final Score"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Community flag badge -->
            <TextView
                android:id="@+id/tvCommunityFlagged"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_flag_badge"
                android:padding="10dp"
                android:text="⚑  Community flagged URL"
                android:textColor="@color/risk_high"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Score breakdown -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.WebHawk.Card.Inner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Score Breakdown"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginBottom="10dp" />

                    <!-- Grid of stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView android:id="@+id/tvRedirectCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/text_primary" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Redirects"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView android:id="@+id/tvUniqueDomains"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textSize="22sp"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/text_primary" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Domains"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView android:id="@+id/tvShortener"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No"
                                android:textSize="22sp"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/text_primary" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Shortener"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView android:id="@+id/tvSuspiciousTld"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No"
                                android:textSize="22sp"
                                android:fontFamily="@font/inter_bold"
                                android:textColor="@color/text_primary" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bad TLD"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Local vs Global scores -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView android:id="@+id/tvLocalScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:textSize="18sp"
                                android:fontFamily="@font/inter_semibold"
                                android:textColor="@color/accent" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Local (×0.7)"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView android:id="@+id/tvGlobalScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:textSize="18sp"
                                android:fontFamily="@font/inter_semibold"
                                android:textColor="@color/accent" />
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Global (×0.3)"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Explanation -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.WebHawk.Card.Inner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analysis"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvExplanation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.7" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Redirect chain -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardChain"
                style="@style/Widget.WebHawk.Card.Inner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Redirect Chain"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginBottom="8dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvChain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Flag actions -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFlag"
                style="@style/Widget.WebHawk.Button.Destructive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/flag_url"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvLoginToFlag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to flag this URL for the community"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDismiss"
                style="@style/Widget.WebHawk.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dismiss" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
