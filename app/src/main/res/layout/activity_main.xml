<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WebHawk"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipUser"
            style="@style/Widget.WebHawk.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sign_in_to_flag" />

    </LinearLayout>

    <!-- Scroll content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="120dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- Service warning -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardServiceWarning"
                style="@style/Widget.WebHawk.Card.Warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Accessibility Service Disabled"
                        android:textColor="@color/risk_high"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_semibold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Enable WebHawk in Accessibility Settings to monitor live browser redirects."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEnableService"
                        style="@style/Widget.WebHawk.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="10dp"
                        android:text="Enable Now"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- URL input card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.WebHawk.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analyze URL"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUrl"
                        style="@style/Widget.WebHawk.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/enter_url_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUrl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri"
                            android:imeOptions="actionSearch"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScan"
                        style="@style/Widget.WebHawk.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/scan" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Scan status card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatus"
                style="@style/Widget.WebHawk.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <ProgressBar
                        android:id="@+id/progressStatus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:indeterminateTint="@color/accent"
                        android:visibility="visible" />

                    <TextView
                        android:id="@+id/tvStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Working..."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopScan"
                        style="@style/Widget.WebHawk.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:text="Stop &amp; Analyze"
                        android:textSize="12sp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Reset -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                style="@style/Widget.WebHawk.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="Reset"
                android:visibility="gone" />

            <!-- Info card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.WebHawk.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="How it works"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_semibold"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Enter any URL to check\n2. WebHawk checks the global flag database\n3. If clean, enables live redirect monitoring in Chrome\n4. Counts redirects, domains, and timing patterns\n5. Produces an explainable risk score\n6. You can flag suspicious URLs to protect the community"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
